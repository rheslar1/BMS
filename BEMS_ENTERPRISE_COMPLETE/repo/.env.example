# MySQL
MYSQL_HOST=db
MYSQL_USER=root
MYSQL_PASSWORD=root
MYSQL_DATABASE=bems

# Node.js Web API
PORT=3000
WATCHDOG_INTERVAL_MS=30000
TELEMETRY_STREAM_INTERVAL_MS=5000
BEMS_REQUIRE_AUTH=false
BEMS_API_TOKEN=
BEMS_MANAGEMENT_TOKEN=
KAFKA_BROKERS=kafka:9092
KAFKA_CLIENT_ID=bems-node-api

# Python AI service
AI_SERVICE_URL=http://ai-service:8000
AI_GRPC_ENDPOINT=ai-service:50052

# Optional C++ edge-core gRPC endpoint.
# When unset, the Node API uses local fallback responses for edge calls.
EDGE_GRPC_ENDPOINT=

# AI physics simulation and utility demand response integration.
ENERGYPLUS_BINARY=
ENERGYPLUS_MODEL_FILE=
ENERGYPLUS_WEATHER_FILE=
UTILITY_PROVIDER=
UTILITY_DR_PROTOCOL=OpenADR-ready REST adapter

# BACnet/IP binding for edge-core deployments.
# Leave empty to bind 0.0.0.0.
BACNET_LOCAL_IP=

# React UI
VITE_API_URL=http://localhost:3000

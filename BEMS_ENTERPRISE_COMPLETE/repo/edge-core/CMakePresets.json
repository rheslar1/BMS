{
  "version": 3,
  "configurePresets": [
    {
      "name": "default",
      "displayName": "Default C++17 build",
      "generator": "Unix Makefiles",
      "binaryDir": "${sourceDir}/build/default",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "RelWithDebInfo"
      }
    },
    {
      "name": "asan-ubsan",
      "displayName": "AddressSanitizer and UndefinedBehaviorSanitizer",
      "inherits": "default",
      "binaryDir": "${sourceDir}/build/asan-ubsan",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "BEMS_ENABLE_SANITIZERS": "ON"
      }
    },
    {
      "name": "tsan",
      "displayName": "ThreadSanitizer",
      "inherits": "default",
      "binaryDir": "${sourceDir}/build/tsan",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "BEMS_ENABLE_THREAD_SANITIZER": "ON"
      }
    },
    {
      "name": "static-analysis",
      "displayName": "Static analysis with clang-tidy",
      "inherits": "default",
      "binaryDir": "${sourceDir}/build/static-analysis",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "BEMS_ENABLE_STATIC_ANALYSIS": "ON"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "default",
      "configurePreset": "default"
    },
    {
      "name": "asan-ubsan",
      "configurePreset": "asan-ubsan"
    },
    {
      "name": "tsan",
      "configurePreset": "tsan"
    },
    {
      "name": "static-analysis",
      "configurePreset": "static-analysis"
    }
  ],
  "testPresets": [
    {
      "name": "default",
      "configurePreset": "default",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "asan-ubsan",
      "configurePreset": "asan-ubsan",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "tsan-threaded",
      "configurePreset": "tsan",
      "filter": {
        "include": {
          "name": "edge-core-(service|bounded-queue)-tests"
        }
      },
      "output": {
        "outputOnFailure": true
      }
    }
  ]
}
